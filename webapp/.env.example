# Required for the Improvement Agent and Executive Report narrative summary.
# Without this, those two stages still run but return computed metrics only
# (no AI-generated text) instead of crashing.
GOOGLE_API_KEY=

# Optional: minimum seconds enforced between successive Gemini calls
# (Improvement Agent, then Executive Report Agent). Raise this if you're
# still hitting 429 rate limits on the free tier. Default: 4 seconds.
GEMINI_MIN_SECONDS_BETWEEN_CALLS=4

# Optional but strongly recommended: raises the GitHub API rate limit from
# 60 requests/hour (unauthenticated) to 5000 requests/hour.
# Create one at https://github.com/settings/tokens (no special scopes needed
# for public repositories).
GITHUB_TOKEN=
